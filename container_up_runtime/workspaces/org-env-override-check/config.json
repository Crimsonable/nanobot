    "sendProgress": true,
    "sendToolHints": false,
    "bridge": {
      "enabled": true,
      "bridgeUrl": "ws://container-up:8080/ws/bridge",
      "bridgeToken": "test-token",
      "allowFrom": [
        "user-1",
        "user-2"
      ]
    }
  },
  "providers": {
    "vllm": {
      "apiKey": "env-key",
      "apiBase": "http://env-override.example/v1"
    }
  },
  "agents": {
    "defaults": {
      "model": "env-model"
    }
  }
}
