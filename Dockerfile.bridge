FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app \
    GATEWAY_PORT=18790

WORKDIR /app

RUN apt-get update && \
    apt-get install -y --no-install-recommends curl build-essential && \
    rm -rf /var/lib/apt/lists/*

# Copy source code. workspace/ is excluded by .dockerignore and should be mounted at runtime.
COPY pyproject.toml README.md LICENSE ./
RUN mkdir -p nanobot && touch nanobot/__init__.py
COPY bridge/ bridge/
COPY start_nanobot_bridge.sh start_org_router.sh ./

RUN uv pip install --system --no-cache . playwright && \
    python -m playwright install --with-deps chromium && \
    chmod +x /app/start_nanobot_bridge.sh /app/start_org_router.sh

EXPOSE 18790

ENTRYPOINT ["/app/start_org_router.sh"]
